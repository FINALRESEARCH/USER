# Copy to .env and fill in. .env is gitignored and NEVER committed.
# For phone/web (cloud) Claude Code sessions, set these same values as
# Claude Code web "environment secrets" — the cloud sandbox cannot read this file.

# Evenings personal API key — https://evenings.fm (account settings / API)
EVENINGS_API_KEY=

# Are.na personal access token — https://www.are.na/settings/personal-access-tokens
ARENA_TOKEN=

# Target Are.na channel slug or numeric id (where mixes get published)
# Double check this against the real channel (GET /v3/channels/<slug>) before relying on it —
# nothing validates it at rest, and a wrong slug just 404s the next publish.
ARENA_CHANNEL=

# Live site base URL + shared secret for the `publish.py revalidate` step (see WEBAPP.md).
# REVALIDATE_SECRET must match the value set on the Vercel project's env vars.
SITE_URL=
REVALIDATE_SECRET=

# Optional overrides (defaults shown)
# EVENINGS_API_BASE=https://api.evenings.co/v1
# ARENA_API_BASE=https://api.are.na/v3
